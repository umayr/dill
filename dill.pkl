module dill

class Port {
  target: Int
  published: Int?
  protocol: "tcp" | "udp" | "sctp" = "tcp"
  host_ip: String?
}

class Mount {
  type: "volume" | "bind" | "tmpfs" = "volume"
  source: String?
  target: String
  read_only: Boolean = false
}

class HealthCheck {
  test: List<String> | String
  interval: Duration?
  timeout: Duration?
  retries: Int?
  start_period: Duration?
}

class Service {
  image: String
  container_name: String?
  restart: "no" | "always" | "on-failure" | "unless-stopped" = "no"
  pull_policy: "always" | "missing" | "never" = "missing"
  environment: Mapping<String, String>?
  volumes: List<Mount | String>?
  ports: List<Port | String>?
  labels: Mapping<String, String>?
  depends_on: List<String>?
  command: List<String>?
  network_mode: String?
  healthcheck: HealthCheck?
  user: String?
  init: Boolean?
  cap_add: List<String>?
  devices: List<String>?
  cpuset: String?
}

class DillConfig {
  /// Stack name used for container labels and network naming.
  /// When omitted, a deterministic adjective-animal name is derived from the config file path.
  name: String?
  services: Mapping<String, Service>
  /// Specify the container engine to use for this deployment
  engine: "podman" | "docker" = "podman"
}

config: DillConfig

output {
  // Pkl's JSON renderer cannot serialise Duration natively.
  // Convert to {value, unit} so the Go side can reconstruct time.Duration.
  renderer = new JsonRenderer {
    converters {
      [Duration] = (d) -> new Dynamic { ["value"] = d.value; ["unit"] = d.unit }
    }
  }
}
