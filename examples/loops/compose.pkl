amends "package://github.com/umayr/dill/releases/download/v1.0.0/dill@1.0.0"

local baseCache = new Service {
  image = "redis:alpine"
  restart = "unless-stopped"
}

config {
  engine = "podman"
  services {
    for (i in 1..3) {
      ["cache-node-\\(i)"] = baseCache(new {
        ports = List("637\\(i):6379")
      })
    }
  }
}