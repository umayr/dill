amends "../../dill.pkl"

local baseCache = new Service {
  image = "redis:alpine"
  restart = "unless-stopped"
}

config {
  name = "cache-cluster"
  engine = "podman"
  services {
    for (i in IntSeq(1, 3)) {
      ["cache-node-\(i)"] = (baseCache) {
        ports = List("637\(i):6379")
      }
    }
  }
}
